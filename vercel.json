{
  "rewrites": [
    {
      "source": "/api/mangadex/:path*",
      "destination": "/api/mangadex-proxy?path=:path*"
    },
    {
      "source": "/manga-image/:url*",
      "destination": "/api/mangadex-img?url=:url*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}